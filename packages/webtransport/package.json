{
  "name": "@webtransport-bun/webtransport",
  "version": "0.1.0",
  "description": "Production-focused WebTransport for Bun with datagrams and streams via a Rust napi-rs addon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vmeansdev/webtransport-bun.git"
  },
  "homepage": "https://github.com/vmeansdev/webtransport-bun#readme",
  "bugs": {
    "url": "https://github.com/vmeansdev/webtransport-bun/issues"
  },
  "keywords": [
    "bun",
    "webtransport",
    "quic",
    "napi-rs",
    "realtime"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prebuild": "cd ../.. && bun run build:native && mkdir -p packages/webtransport/prebuilds && cp crates/native/webtransport-native.*.node packages/webtransport/prebuilds/ 2>/dev/null || true",
    "prebuild:checksums": "cd prebuilds 2>/dev/null && shasum -a 256 *.node > SHA256SUMS 2>/dev/null || true"
  },
  "os": ["darwin", "linux"],
  "cpu": ["arm64", "x64"]
}
