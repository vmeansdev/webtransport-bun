{
  "name": "webtransport-bun",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "build:native": "bunx @napi-rs/cli build --cwd crates/native --platform --release",
    "test": "bun test packages/",
    "test:parity": "bun test packages/webtransport/test/parity-*.test.ts",
    "typecheck": "tsc -p tsconfig.json",
    "test:interop": "cd tools/interop && bun run playwright test",
    "test:load": "bun tools/load/load.ts",
    "test:soak": "bun tools/load/soak.ts",
    "test:overload": "bun tools/load/overload-session.ts",
    "test:overload-addon": "bun tools/load/overload-addon.ts",
    "test:load-addon": "bun tools/load/load-addon.ts",
    "test:load-scale-addon": "bun tools/load/load-scale-addon.ts",
    "test:soak-addon": "bun tools/load/soak-addon.ts",
    "bench:datagram": "bun tools/bench/datagram-throughput.ts",
    "bench:handshake": "bun tools/bench/handshake-latency.ts",
    "bench:stream": "bun tools/bench/stream-throughput.ts",
    "bench:baseline": "bun tools/bench/baseline.ts",
    "bench:regress": "bun tools/bench/bench-regress.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
