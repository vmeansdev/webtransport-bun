{
	"name": "webtransport-bun",
	"private": true,
	"license": "MIT",
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"setup:hooks": "bash scripts/install-git-hooks.sh",
		"build:native": "bunx @napi-rs/cli build --cwd crates/native --platform --release",
		"example:echo": "bun run examples/echo-playground/server.ts",
		"example:echo:cert": "mkdir -p examples/echo-playground/certs && openssl req -x509 -newkey ec -pkeyopt ec_paramgen_curve:prime256v1 -days 10 -nodes -keyout examples/echo-playground/certs/key.pem -out examples/echo-playground/certs/cert.pem -subj '/CN=localhost' -addext 'subjectAltName = DNS:localhost,IP:127.0.0.1'",
		"example:echo:docker": "bash examples/echo-playground/run-docker.sh",
		"example:compose:collab": "bash examples/compose-collab/run-compose.sh",
		"test": "WEBTRANSPORT_SUPPRESS_INSECURE_SKIP_VERIFY_WARN=1 bun test packages/",
		"test:ci-local": "bash scripts/test_ci_local.sh",
		"test:parity": "WEBTRANSPORT_SUPPRESS_INSECURE_SKIP_VERIFY_WARN=1 bun test --max-concurrency=1 packages/webtransport/test/parity-*.test.ts",
		"typecheck": "tsc -p tsconfig.json",
		"test:interop": "cd tools/interop && WEBTRANSPORT_SUPPRESS_INSECURE_SKIP_VERIFY_WARN=1 bun run playwright test",
		"test:load": "bun tools/load/load.ts",
		"test:soak": "bun tools/load/soak.ts",
		"test:overload": "bun tools/load/overload-session.ts",
		"test:overload-addon": "WEBTRANSPORT_SUPPRESS_INSECURE_SKIP_VERIFY_WARN=1 bun tools/load/overload-addon.ts",
		"test:load-addon": "WEBTRANSPORT_SUPPRESS_INSECURE_SKIP_VERIFY_WARN=1 bun tools/load/load-addon.ts",
		"test:load-scale-addon": "WEBTRANSPORT_SUPPRESS_INSECURE_SKIP_VERIFY_WARN=1 bun tools/load/load-scale-addon.ts",
		"test:load-profiles-addon": "WEBTRANSPORT_SUPPRESS_INSECURE_SKIP_VERIFY_WARN=1 bun tools/load/load-profiles-addon.ts",
		"test:soak-addon": "bun tools/load/soak-addon.ts",
		"test:soak-addon:1h": "SOAK_DURATION=3600 bun tools/load/soak-addon.ts",
		"test:soak-addon:24h": "SOAK_DURATION=86400 bun tools/load/soak-addon.ts",
		"test:soak-addon:72h": "SOAK_DURATION=259200 bun tools/load/soak-addon.ts",
		"bench:datagram": "bun tools/bench/datagram-throughput.ts",
		"bench:handshake": "bun tools/bench/handshake-latency.ts",
		"bench:stream": "bun tools/bench/stream-throughput.ts",
		"bench:baseline": "bun tools/bench/baseline.ts",
		"bench:regress": "bun tools/bench/bench-regress.ts",
		"release:npm": "npm publish -w @webtransport-bun/webtransport --access public"
	},
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@types/bun": "latest",
    "@types/node": "^22.15.3",
    "typescript": "^5"
  }
}
