#!/usr/bin/env bash
set -euo pipefail

if ! command -v git >/dev/null 2>&1; then
  echo "pre-commit: git is required" >&2
  exit 1
fi

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  exit 0
fi

declare -a rust_files=()
declare -a tsjs_files=()
cargo_cmd=""

while IFS= read -r -d '' file; do
  case "$file" in
    *.rs)
      rust_files+=("$file")
      ;;
    *.ts|*.tsx|*.js|*.jsx|*.mjs|*.cjs)
      tsjs_files+=("$file")
      ;;
  esac
done < <(git diff --cached --name-only --diff-filter=ACMR -z)

if [ "${#rust_files[@]}" -gt 0 ]; then
  if command -v cargo >/dev/null 2>&1; then
    cargo_cmd="$(command -v cargo)"
  elif [ -x "${HOME}/.cargo/bin/cargo" ]; then
    cargo_cmd="${HOME}/.cargo/bin/cargo"
  else
    echo "pre-commit: cargo is required for staged Rust files" >&2
    echo "pre-commit: install Rust toolchain (https://rustup.rs) or ensure cargo is on PATH" >&2
    exit 1
  fi

  echo "pre-commit: formatting Rust files with cargo fmt"
  "${cargo_cmd}" fmt --all -- "${rust_files[@]}"
  git add -- "${rust_files[@]}"
  echo "pre-commit: running clippy"
  "${cargo_cmd}" clippy --workspace -- -D clippy::all
fi

if [ "${#tsjs_files[@]}" -gt 0 ]; then
  if ! command -v bunx >/dev/null 2>&1; then
    echo "pre-commit: bunx is required to format TS/JS files" >&2
    exit 1
  fi
  echo "pre-commit: formatting TS/JS files with biome"
  bunx biome format --write "${tsjs_files[@]}"
  git add -- "${tsjs_files[@]}"
fi
